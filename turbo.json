{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".env.example"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["NODE_ENV"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**", "target/release/**"]
    },
    "build-storybook": {
      "dependsOn": ["^build", "build"],
      "env": ["NODE_ENV"],
      "outputs": ["storybook-static/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build", "build"],
      "env": ["CI", "GATE_PROOF"],
      "outputs": []
    },
    "test:a11y": {
      "dependsOn": ["^build", "build", "build-storybook"],
      "env": ["CI"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "docker:build": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["DOCKER_*", "GITHUB_*"]
    },
    "contract:check": {
      "outputs": []
    },
    "fuzz:cross-tenant": {
      "cache": false,
      "env": [
        "FUZZ_SEED",
        "FUZZ_GATE_MODE",
        "DATABASE_URL",
        "FUZZ_APP_USER",
        "FUZZ_APP_PASSWORD",
        "GITHUB_RUN_ID"
      ],
      "outputs": ["artifacts/fuzz/**"]
    }
  }
}
