{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".env.example"],
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["NODE_ENV"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**", "target/release/**"]
    },
    "build-storybook": {
      "dependsOn": ["^build", "build"],
      "env": ["NODE_ENV"],
      "outputs": ["storybook-static/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "env": ["CI", "GATE_PROOF"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "test:a11y": {
      "dependsOn": ["build"],
      "env": ["CI"],
      "outputs": ["pa11y-screenshots/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "docker:build": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": ["DOCKER_*", "GITHUB_*"]
    }
  }
}
