{
  "name": "main — required CI, a11y, schema, fuzz",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    { "type": "deletion" },
    { "type": "non_fast_forward" },
    {
      "type": "pull_request",
      "parameters": {
        "required_approving_review_count": 0,
        "dismiss_stale_reviews_on_push": false,
        "require_code_owner_review": false,
        "require_last_push_approval": false,
        "required_review_thread_resolution": false,
        "allowed_merge_methods": ["merge", "squash", "rebase"]
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": false,
        "do_not_enforce_on_create": true,
        "required_status_checks": [
          { "context": "CI / Toolchain (Node 24 + pnpm 10.33.0)" },
          { "context": "CI / Smoke (install / build / lint / typecheck / test / format)" },
          { "context": "CI / Control plane (integration)" },
          { "context": "CI / Ingest (pytest)" },
          { "context": "CI / SBOM (source — SPDX + CycloneDX)" },
          { "context": "CI / CVE scan (grype)" },
          { "context": "CI / Dependency review (PR diff)" },
          { "context": "a11y / jsx-a11y" },
          { "context": "a11y / storybook-a11y" },
          { "context": "a11y / playwright-a11y" },
          { "context": "a11y / pa11y" },
          { "context": "compose-smoke / compose-smoke" },
          { "context": "schema / canonical-memory-schema" },
          { "context": "fuzz / cross-tenant-fuzz" }
        ]
      }
    }
  ]
}
