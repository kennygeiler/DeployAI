{
  "name": "@deployai/foia-verifier",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TS stub for offline TSR structure checks (Epic 12 Go consumer; Story 1-13).",
  "main": "./dist/verify.js",
  "types": "./dist/verify.d.ts",
  "exports": {
    ".": {
      "types": "./dist/verify.d.ts",
      "default": "./dist/verify.js"
    }
  },
  "files": ["dist/**", "certs/README.md"],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^2.1.9"
  }
}
