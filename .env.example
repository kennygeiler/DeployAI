# DeployAI — Environment variable template
#
# Copy to `.env` at the repo root and fill in. `.env` is gitignored; this
# `.env.example` is the single source of truth for required/optional vars
# and is hashed by Turborepo into build cache keys (via globalDependencies).
#
# Story 1.1 intentionally keeps this minimal — real variables land with the
# services that consume them (Stories 1.3 onward).

# --- Runtime ---
# NODE_ENV=development   # 'development' | 'production' | 'test'
# CI=                    # set to 'true' in CI runners; affects cache behavior

# --- Control plane (services/control-plane) — see docs/auth/sso-setup.md ---
# DEPLOYAI_OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# DEPLOYAI_OIDC_CLIENT_ID=
# DEPLOYAI_OIDC_CLIENT_SECRET=
# DEPLOYAI_OIDC_REDIRECT_URI=https://localhost:8000/auth/oidc/callback
# DEPLOYAI_JWT_PRIVATE_KEY_PATH=
# DEPLOYAI_JWT_PUBLIC_KEY_PATHS=
# DEPLOYAI_REDIS_URL=redis://127.0.0.1:6379/0
# OpenTelemetry (control plane): set endpoint to enable OTLP/HTTP export of app + LLM token metrics
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# or per-signal: OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://127.0.0.1:4318/v1/metrics
# OTEL_SERVICE_NAME=deployai-control-plane
# OTEL_METRIC_EXPORT_INTERVAL=5000
# OTEL_SDK_DISABLED=        # "true" to keep the SDK off (e.g. local dev without a collector)
# Cartographer (services/cartographer) — one-line JSON triage logs (no message body)
# When TRIAGE_LOG_JSON=1, event_id/tenant_id are SHA-256 prefixes by default. Set the second var to "raw" only if you need correlators in logs.
# DEPLOYAI_CARTOGRAPHER_TRIAGE_LOG_JSON=1
# DEPLOYAI_CARTOGRAPHER_TRIAGE_LOG_IDENTIFIERS=raw
# M365 calendar (Epic 3) — can reuse OIDC app + secrets; callback URI must be registered separately
# DEPLOYAI_M365_CALENDAR_REDIRECT_URI=https://localhost:8000/integrations/m365-calendar/callback
# M365 mail (Epic 3) — add Mail.Read + separate reply URL in Entra
# DEPLOYAI_M365_MAIL_REDIRECT_URI=https://localhost:8000/integrations/m365-mail/callback
# M365 Teams transcripts (Epic 3) — Calendars.Read + OnlineMeetings.Read + OnlineMeetingTranscript.Read.All
# DEPLOYAI_M365_TEAMS_REDIRECT_URI=https://localhost:8000/integrations/m365-teams/callback
# Optional email body storage (dev/tests: stub on disk; s3 is not implemented yet)
# DEPLOYAI_INGEST_EMAIL_BODY_MODE=stub
# DEPLOYAI_INGEST_EMAIL_BODY_STUB_DIR=
# Meeting/voice file upload (Epic 3 Story 3-4) — S3 direct upload via control-plane presign
# DEPLOYAI_UPLOAD_ARTIFACT_S3_BUCKET=
# DEPLOYAI_UPLOAD_ARTIFACT_S3_REGION=us-east-1
# DEPLOYAI_UPLOAD_ARTIFACT_S3_KEY_PREFIX=ingest/artifacts
# After /upload/artifacts/complete, enqueue a transcribe job (optional). Consumer: python -m control_plane.workers.transcribe_upload
# DEPLOYAI_INGEST_UPLOAD_SQS_URL=
# DEPLOYAI_UPLOAD_ASR_MODE=stub
# AWS default credential chain (e.g. AWS_PROFILE) must allow s3:PutObject on the bucket and sqs:SendMessage on the queue URL
# Optional overrides (else DEPLOYAI_OIDC_* is used for issuer/client id/secret)
# DEPLOYAI_M365_OAUTH_ISSUER=
# DEPLOYAI_M365_OAUTH_CLIENT_ID=
# DEPLOYAI_M365_OAUTH_CLIENT_SECRET=
# Microsoft Graph request throttling (Story 3-7, NFR19) — token-bucket cap per process
# DEPLOYAI_GRAPH_INGEST_RPS=1000

# Google Gmail — OAuth + sync (register redirect in Google Cloud Console)
# DEPLOYAI_GOOGLE_GMAIL_CLIENT_ID=
# DEPLOYAI_GOOGLE_GMAIL_CLIENT_SECRET=
# DEPLOYAI_GOOGLE_GMAIL_REDIRECT_URI=https://localhost:8000/integrations/google-gmail/callback

# Slack — OAuth install + Events API (register redirect + Request URL in Slack app settings)
# DEPLOYAI_SLACK_CLIENT_ID=
# DEPLOYAI_SLACK_CLIENT_SECRET=
# DEPLOYAI_SLACK_REDIRECT_URI=https://localhost:8000/integrations/slack/oauth/callback
# DEPLOYAI_SLACK_SIGNING_SECRET=

# Prometheus scrape (internal API; use same key as other /internal/v1 routes)
# GET /internal/v1/metrics with X-DeployAI-Internal-Key
# DEPLOYAI_INTERNAL_API_KEY=

# --- apps/web — strategist surfaces (optional; see docs/dev-environment.md, whats-actually-here.md) ---
# GET JSON array of DigestTopItem for /digest — unset uses code fixtures (MORNING_DIGEST_TOP).
# STRATEGIST_DIGEST_SOURCE_URL=https://localhost:4000/mock/digest.json
# GET JSON { candidates, patterns? } for /evening — unset uses mock slice + patterns.
# STRATEGIST_EVENING_SYNTHESIS_SOURCE_URL=https://localhost:4000/mock/evening.json
# Oracle (or other agent) HTTP liveness for strategist-activity — non-OK marks agent degraded when configured.
# DEPLOYAI_ORACLE_HEALTH_URL=http://127.0.0.1:8080/healthz
# Client poll interval (build-time) for /api/internal/strategist-activity while tab is visible (default 30000).
# NEXT_PUBLIC_DEPLOYAI_STRATEGIST_ACTIVITY_POLL_MS=30000
# Control plane base + internal key for meeting-presence + ingestion in loadStrategistActivityForActor (also used elsewhere).
# DEPLOYAI_CONTROL_PLANE_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_CONTROL_PLANE_URL=http://127.0.0.1:8000
# DEPLOYAI_INTERNAL_API_KEY=your-internal-key
# Pilot / staging: require x-deployai-tenant on strategist routes (403 if missing). See docs/pilot/session-and-headers.md.
# DEPLOYAI_STRATEGIST_REQUIRE_TENANT=1

# services/ingest (pytest) — run from services/ingest: uv sync && uv run pytest
# (no env vars required for unit tests)

# --- Future additions (placeholders for other stories) ---
# DATABASE_URL=          # Story 1.8 (canonical memory schema)
# ANTHROPIC_API_KEY=     # Story 3.1 (LLM provider abstraction) & Epic 4 LLM-judge (apps/eval)
# ANTHROPIC_MODEL=       # optional; default claude-3-5-haiku-20241022
# DEPLOYAI_EVAL_JUDGE_MODE=stub  # set to llm for live judge (see apps/eval)
# DEPLOYAI_EVAL_JUDGE_INPUT=     # path to JSON input; optional; default built-in smoke
# DEPLOYAI_MONOREPO_ROOT=        # if judge runs outside repo root
# OPENAI_API_KEY=        # Story 3.1 (secondary LLM)
# DEPLOYAI_ANTHROPIC_SECRET_ARN=  # optional: plain secret string in AWS SM when `ANTHROPIC_API_KEY` is unset (requires boto3)
# DEPLOYAI_OPENAI_SECRET_ARN=     # optional: same for OpenAI
# AWS_REGION=us-east-1   # Story 1.2 (CI, KMS, etc.); also used for Secrets Manager when ARNs are set
