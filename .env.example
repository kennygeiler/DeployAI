# DeployAI — Environment variable template
#
# Copy to `.env` at the repo root and fill in. `.env` is gitignored; this
# `.env.example` is the single source of truth for required/optional vars
# and is hashed by Turborepo into build cache keys (via globalDependencies).
#
# Story 1.1 intentionally keeps this minimal — real variables land with the
# services that consume them (Stories 1.3 onward).

# --- Runtime ---
# NODE_ENV=development   # 'development' | 'production' | 'test'
# CI=                    # set to 'true' in CI runners; affects cache behavior

# --- Control plane (services/control-plane) — see docs/auth/sso-setup.md ---
# DEPLOYAI_OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# DEPLOYAI_OIDC_CLIENT_ID=
# DEPLOYAI_OIDC_CLIENT_SECRET=
# DEPLOYAI_OIDC_REDIRECT_URI=https://localhost:8000/auth/oidc/callback
# DEPLOYAI_JWT_PRIVATE_KEY_PATH=
# DEPLOYAI_JWT_PUBLIC_KEY_PATHS=
# DEPLOYAI_REDIS_URL=redis://127.0.0.1:6379/0
# M365 calendar (Epic 3) — can reuse OIDC app + secrets; callback URI must be registered separately
# DEPLOYAI_M365_CALENDAR_REDIRECT_URI=https://localhost:8000/integrations/m365-calendar/callback
# Optional overrides (else DEPLOYAI_OIDC_* is used for issuer/client id/secret)
# DEPLOYAI_M365_OAUTH_ISSUER=
# DEPLOYAI_M365_OAUTH_CLIENT_ID=
# DEPLOYAI_M365_OAUTH_CLIENT_SECRET=

# --- Future additions (placeholders for other stories) ---
# DATABASE_URL=          # Story 1.8 (canonical memory schema)
# ANTHROPIC_API_KEY=     # Story 3.1 (LLM provider abstraction)
# OPENAI_API_KEY=        # Story 3.1 (secondary LLM)
# AWS_REGION=us-east-1   # Story 1.2 (CI, KMS, etc.)
