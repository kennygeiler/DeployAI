# Story 1.7 — docker-compose reference dev environment.
# Copy this to infra/compose/.env before running `make dev`.
# The .env file is gitignored; never commit secrets.

# Postgres
POSTGRES_DB=deployai
POSTGRES_USER=deployai
POSTGRES_PASSWORD=deployai-local-dev
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO
MINIO_ROOT_USER=deployai
MINIO_ROOT_PASSWORD=deployai-local-dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# FreeTSA stub
FREETSA_STUB_PORT=2020

# Keycloak (OIDC issuer for local dev — Phase D inc 1b, see docs/auth/oidc.md).
# Dev-only credentials; override for any non-local env.
KEYCLOAK_PORT=8090
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Control-plane (FastAPI)
CONTROL_PLANE_PORT=8000
CONTROL_PLANE_DATABASE_URL=postgresql+asyncpg://deployai:deployai-local-dev@postgres:5432/deployai
CONTROL_PLANE_REDIS_URL=redis://redis:6379/0
CONTROL_PLANE_S3_ENDPOINT=http://minio:9000
CONTROL_PLANE_TSA_URL=http://freetsa-stub:2020/tsr

# apps/web (Next.js)
WEB_PORT=3000
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:8000

# v2 Phase 4 — MCP inbound server (scope-v2 §8). Standalone uvicorn service
# that an advisor's Claude desktop (or any MCP client) connects to.
MCP_SERVER_PORT=3030
MCP_SERVER_DATABASE_URL=postgresql+asyncpg://deployai:deployai-local-dev@postgres:5432/deployai

# v2 Phase 2 — Agent Kenny LangGraph multi-step loop (scope-v2 §6).
# When unset / 0, the CP /chat/stream-v2 endpoint returns 404 and the web
# client uses the legacy /chat/stream endpoint. Flip on per pilot tenant.
DEPLOYAI_AGENT_KENNY_V2_ENABLED=0
NEXT_PUBLIC_AGENT_KENNY_V2_ENABLED=0

# Phase C inc 12.1 — `make backup` (see docs/ops/backup.md).
# S3_BUCKET is mandatory; `make backup` refuses to run without it so a
# missing prod value can't silently fall through to a local default.
# Uncomment to back up to the in-stack MinIO from your host.
# S3_BUCKET=deployai-dev-backups
# S3_PREFIX=deployai/backups
# S3_ENDPOINT_URL=http://localhost:9000
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=deployai
# AWS_SECRET_ACCESS_KEY=deployai-local-dev
