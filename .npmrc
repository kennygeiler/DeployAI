# pnpm configuration for DeployAI
# See: https://pnpm.io/npmrc

# Hard-fail `pnpm install` (and every other pnpm command) when the current
# Node or pnpm version is outside the `engines` range declared in package.json.
# Without this, pnpm only warns — which is how Node 22 / Node 25 / pnpm 9 slip
# in unnoticed and cause downstream breakage far from the install step.
engine-strict=true

# Fail `pnpm install` if pnpm-lock.yaml would need to change on a CI box.
# Keeps dependency updates explicit (they must go through a local `pnpm install`
# and be committed), which is essential for SLSA L2 provenance (Story 1.2).
frozen-lockfile=true

# Prefer the workspace-local copy of any package when resolving imports in
# dev. Matches the monorepo intent: packages/* should dogfood their own source.
prefer-workspace-packages=true
