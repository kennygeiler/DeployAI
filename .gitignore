_bmad-output/tmp/
_bmad-output/cache/
.bmad-cache/

# ─────────────────────── Accessibility / Playwright / pa11y (Story 1.6) ───────────────────────
# Playwright HTML report + result traces (generated per run; gitignored
# so local runs don't pollute the working tree; CI uploads them as
# workflow artifacts on failure).
playwright-report/
test-results/
# pa11y-ci screen captures (local dev aid; never committed).
pa11y-screenshots/
# Local Chrome install created by `@puppeteer/browsers install` if run
# without `--path` — we always redirect to ~/.cache/puppeteer, but
# defensive-ignore the CWD fallback anywhere in the tree (pnpm filter
# commands run from root, but direct `cd apps/web && ...` invocations
# are routine) so an accidental install doesn't balloon the commit.
**/chrome/
# App UI package path is named "chrome" (strategist shell); do not conflate with Google Chrome.
!apps/web/src/components/chrome/
!apps/web/src/components/chrome/**

# ─────────────────────── Fuzz / contract evidence JSON (Story 1.10+) ───────────────────────
# Generated locally and by `pnpm turbo run fuzz:cross-tenant`; CI uploads as a
# workflow artifact — never commit the bytes.
artifacts/fuzz/
artifacts/replay-parity/
artifacts/quarterly/
# VPAT stub JSON from `vpat-aggregate` / CI — ship via workflow artifacts, not the repo
artifacts/vpat/
services/control-plane/artifacts/fuzz/

# ─────────────────────── Misc ───────────────────────
*.tsbuildinfo
.history/
.vs/
.eslintcache
.stylelintcache
