# Un-ignore JavaScript/TypeScript lib directories that collided with the
# Python venv `lib/` pattern above. The Python `lib/` rule is unanchored and
# silently swallowed shadcn-initialized `apps/web/src/lib/` (the `cn` helper
# at `apps/web/src/lib/utils.ts`). Keep this list explicit — if a new
# workspace adds a `src/lib/` tree, add an allow-entry here.
!apps/web/src/lib/
!apps/web/src/lib/**
!packages/shared-ui/src/lib/
!packages/shared-ui/src/lib/**
# Story 1.11 — contract JSON-schema build helper (not Python site-packages)
!packages/contracts/scripts/lib/
!packages/contracts/scripts/lib/**
*.manifest
*.spec
.venv/
venv/
env/
ENV/
.env.python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
coverage.xml
*.cover
*.log
uv.lock.bak

