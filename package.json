{
  "name": "deployai",
  "version": "0.0.0",
  "private": true,
  "description": "DeployAI — Agentic Deployment System of Record. Polyglot monorepo (Next.js + Tauri + Go + FastAPI).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kennygeiler/DeployAI.git"
  },
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=10.33.0 <11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:a11y": "turbo run test:a11y",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "contract:check": "pnpm --filter @deployai/contracts run contract:check",
    "contract:continuity": "pnpm turbo run contract:continuity",
    "validate:llm-matrix": "pnpm turbo run validate:llm-matrix",
    "validate:llm-matrix:py": "cd packages/llm-provider-py && uv run python scripts/validate_matrix.py",
    "golden:validate": "pnpm --filter @deployai/golden-tools run validate",
    "golden:author": "pnpm --filter @deployai/golden-tools run author",
    "golden:expand-corpus": "pnpm --filter @deployai/golden-tools run expand-corpus",
    "golden:coverage-html": "pnpm --filter @deployai/golden-tools run coverage-html",
    "replay-parity:rules": "pnpm --filter @deployai/eval run replay-parity:rules",
    "replay-parity:judge": "pnpm --filter @deployai/eval run replay-parity:judge",
    "quarterly:report": "node scripts/quarterly-report.mjs",
    "ci:turbo:full": "bash scripts/ci-turbo-full.sh",
    "vpat:aggregate": "pnpm --filter @deployai/vpat-aggregator run vpat-aggregate",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/node": "24.12.2",
    "eslint": "9.39.4",
    "globals": "17.5.0",
    "prettier": "3.8.3",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  }
}
