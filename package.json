{
  "name": "deployai",
  "version": "0.0.0",
  "private": true,
  "description": "DeployAI — Agentic Deployment System of Record. Polyglot monorepo (Next.js + Tauri + Go + FastAPI).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kennygeiler/DeployAI.git"
  },
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": ">=10.33.0 <11.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.2",
    "eslint": "10.2.1",
    "globals": "17.5.0",
    "prettier": "3.8.3",
    "turbo": "2.9.6",
    "typescript": "6.0.3"
  }
}
